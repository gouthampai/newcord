PORT=8080
# For local development with kubectl port-forward (run: make k8s-port-forward), use localhost
# For NodePort access, use localhost:30042
# For in-cluster access, use cassandra.newcord.svc.cluster.local
CASSANDRA_HOSTS=localhost:30042
CASSANDRA_KEYSPACE=newcord
JWT_SECRET=your-secret-key-change-this-in-production
